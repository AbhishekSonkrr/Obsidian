views:
  - type: table
    name: Table
    filters:
      and:
        - file.folder.startsWith("DSA")
    groupBy:
      property: file.folder
      direction: ASC
    order:
      - checkbox
      - file.name
      - tags
    sort:
      - property: tags
        direction: ASC
      - property: file.name
        direction: ASC
    columnSize:
      file.name: 490
    markers: number
